Options -Indexes

<IfModule mod_headers.c>
  Header always unset X-Powered-By
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "same-origin"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^migrations/ - [F,L]
</IfModule>

<FilesMatch "^(config\.php|config\.example\.php|schema\.sql|README\.md)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(sql|md)$">
  Require all denied
</FilesMatch>

LimitRequestBody 16384
